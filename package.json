    "expo": "~54.0.35",
    "expo-font": "~14.0.12",
    "expo-secure-store": "~15.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.16",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "jest": {
    "preset": "jest-expo",
