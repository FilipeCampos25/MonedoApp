# Copy this file to backend/.env for local development.
#
# Local SQLite database. This is also the automatic fallback when
# DATABASE_URL is unset.
DATABASE_URL=sqlite:///./monedo.db

# PostgreSQL example (requires psycopg2-binary from requirements.txt).
# DATABASE_URL=postgresql://monedo:change-me@localhost:5432/monedo

# Generate a long random value for non-development environments.
JWT_SECRET_KEY=change-me-with-a-long-random-secret
APP_TIMEZONE=America/Sao_Paulo
CORS_ORIGINS=*
