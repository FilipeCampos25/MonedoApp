# Web/iOS simulator running on the same computer:
EXPO_PUBLIC_API_URL=http://localhost:8000

# Android Studio emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Physical device (replace with the computer's LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.0.10:8000

# Backend database. SQLite is suitable for local development.
DATABASE_URL=sqlite:///./monedo.db

# PostgreSQL example:
# DATABASE_URL=postgresql://monedo:change-me@localhost:5432/monedo
